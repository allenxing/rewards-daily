    "features": {
      "sectionTitle": "Four Core Abilities",
      "sectionSubtitle": "Tasks, Points, Wishes, and Badges — a complete habit-building ecosystem",
      "task": {
        "title": "Task Habits",
        "desc": "Create custom daily tasks with point rewards and photo proof submissions. Make good habits visible and trackable."
      },
      "points": {
        "title": "Point Rewards",
        "desc": "Earn points by completing tasks. Parents can manually adjust points. Track every change in the activity log."
      },
      "wish": {
        "title": "Wish Rewards",
        "desc": "Kids set wish goals and redeem them with earned points. Learn delayed gratification and goal management."
      },
      "medal": {
        "title": "Achievement Badges",
        "desc": "Unlock milestone badges to build confidence and pride. Every step forward deserves to be celebrated."
      }
    },
    "advantages": {
      "sectionTitle": "Why Rewards Daily",
      "sectionSubtitle": "Lightweight, secure, and ready to use",
      "cloud": {
        "title": "Cloud Storage",
        "desc": "Data persisted on Supabase cloud — securely backed up, never lost."
      },
      "sync": {
        "title": "Multi-device",
        "desc": "Access from phone, tablet, or computer. Data syncs in real time."
      },
      "permissions": {
        "title": "Access Control",
        "desc": "Parent admin and child modes are strictly separated. Safe and reliable."
      },
      "lightweight": {
        "title": "Lightweight",
        "desc": "No backend setup needed. Ready out of the box with zero technical overhead."
      }
    },
    "footer": {
      "text": "© 2026 Rewards Daily — Build Great Habits",
      "subtext": "Powered by Supabase · Secure Cloud · Multi-device Sync"
    }
  },
